<?xml version="1.0" encoding="UTF-8"?>
<!--
  CSV Viewer MSI 설치 정의 (WiX Toolset v4+ / v6).

  빌드:  installer\build_msi.ps1   (내부에서 아래를 실행)
    wix build installer\CSVViewer.wxs -arch x64 \
        -d "DistDir=...\dist\CSV Viewer" -d "ResRoot=...\GUI\res" \
        -o "installer\out\CSV Viewer Setup.msi"

  설치 동작:
    - 64비트 per-machine 설치 (관리자 권한 필요)
    - 설치 경로:  C:\Program Files\CSV Viewer
    - 시스템 환경변수  CSV_VIEWER_HOME = 설치 경로   (제거 시 함께 삭제)
    - 폴더 우클릭 / 폴더 빈 공간(배경) 우클릭 → "Open with CSV Viewer(V)"
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="CSV Viewer"
      Manufacturer="ChickenSlayer"
      Version="1.0.5.0"
      ProductCode="$(var.ProductCode)"
      UpgradeCode="BB893716-5CA4-4B5F-8C68-437174BD6795"
      Scope="perMachine"
      Compressed="yes">

    <!-- ★ ProductCode = '버전별로 결정되는 GUID'(build_msi.ps1 이 Version 으로부터 산출해 주입).
         같은 버전 → 같은 ProductCode, 다른 버전 → 다른 ProductCode. 이 한 가지로 세 동작이 모두 성립:
           · 미설치          → 신규 설치
           · 옛 버전 설치됨   → ProductCode 가 달라 Installed=거짓 → MajorUpgrade(UpgradeCode)가
                                구버전을 감지·제거하고 새 버전 설치 = 업그레이드  (WIX_UPGRADE_DETECTED)
           · 같은 버전 설치됨 → ProductCode 가 같아 Installed=참 → 아래 SetProperty 로 제거 토글
           · 더 최신 설치됨   → 다운그레이드 차단(DowngradeErrorMessage, WIX_DOWNGRADE_DETECTED)
         ※ 과거엔 ProductCode 를 한 GUID 로 고정해, 다른 버전 MSI 를 실행해도 같은 제품으로 인식 →
            업그레이드가 안 되고 제거 토글만 떴다. 그 버그를 '버전별 ProductCode'로 해결한 것.
         ※ FindRelatedProducts 는 '자기 ProductCode' 는 제외하므로, 같은 버전 MSI 를 재실행해도
            업그레이드로 오인하지 않고 정확히 제거 토글이 된다.
         ※ AllowSameVersionUpgrades=yes: 옛 고정-ProductCode 빌드(같은 1.0.0.0, 다른 ProductCode)가
            깔려 있어도 새 빌드를 업그레이드로 깔끔히 교체(1회성 마이그레이션). UpgradeCode 는 불변. -->
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="이미 더 최신 버전의 [ProductName] 이(가) 설치되어 있습니다." />

    <!-- ★ 토글 제거: 이미 설치된 상태에서 이 MSI를 '다시' 실행하면 → 설치가 아니라 '제거'로 동작.
         - Installed                : 이 제품(같은 ProductCode)이 이미 설치돼 있음 = 다시 실행한 경우
         - NOT REMOVE               : msiexec /x 로 부르는 진짜 제거가 아님(중복 처리 방지)
         - NOT UPGRADINGPRODUCTCODE : 업그레이드 중 구버전을 떼는 단계가 아님
         REMOVE=ALL 을 CostFinalize '전'에 세팅해야 전체 제거로 비용계산된다. -->
    <SetProperty Id="REMOVE" Value="ALL" Before="CostFinalize" Sequence="both"
                 Condition="Installed AND NOT REMOVE AND NOT UPGRADINGPRODUCTCODE" />

    <!-- cab을 MSI 안에 포함 → 단일 .msi 파일로 배포 -->
    <MediaTemplate EmbedCab="yes" />

    <!-- 제어판 '프로그램 추가/제거' 목록 아이콘 -->
    <Icon Id="AppIcon.ico" SourceFile="$(var.ResRoot)\button_csv_view.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <!-- 설치 위치: C:\Program Files\CSV Viewer (64비트) -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="CSV Viewer" />
    </StandardDirectory>

    <Feature Id="Main" Title="CSV Viewer" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="IntegrationComponents" />
    </Feature>

    <!-- (앱 본체) PyInstaller onedir 산출물(dist\CSV Viewer) 전체를 자동 수집.
         CSV Viewer.exe 는 INSTALLFOLDER 루트, _python_lib\* 는 하위로 그대로 들어간다. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DistDir)\**" />
    </ComponentGroup>

    <!-- (환경변수 + 우클릭 메뉴) -->
    <ComponentGroup Id="IntegrationComponents" Directory="INSTALLFOLDER">

      <!-- 요구사항 1: 시스템 환경변수 CSV_VIEWER_HOME = 설치 경로.
           Part=all → 단독 값, Permanent=no → 제거 시 삭제. MSI가 변경을 broadcast 하므로
           새로 뜨는 프로세스는 재부팅 없이 값을 본다. -->
      <Component Id="EnvCsvViewerHome">
        <Environment Id="CsvViewerHome"
                     Name="CSV_VIEWER_HOME"
                     Value="[INSTALLFOLDER]"
                     Action="set"
                     Part="all"
                     System="yes"
                     Permanent="no" />
        <RegistryValue Root="HKLM" Key="Software\CSV Viewer"
                       Name="Installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!-- 요구사항 3: 폴더 자체를 우클릭했을 때.
           %V = 우클릭한 폴더 경로 → "CSV Viewer.exe" "그 폴더" 로 실행 -->
      <Component Id="ShellDirectory">
        <RegistryKey Root="HKCR" Key="Directory\shell\OpenWithCSVViewer" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="Open with CSV Viewer(&amp;V)" KeyPath="yes" />
          <RegistryValue Name="Icon" Type="string" Value="[INSTALLFOLDER]CSV Viewer.exe" />
          <RegistryKey Key="command">
            <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]CSV Viewer.exe&quot; &quot;%V&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>

      <!-- 요구사항 4: 폴더 안 빈 공간(배경)을 우클릭했을 때.
           배경 메뉴는 %1 이 비므로 반드시 %V(현재 보고 있는 폴더)를 써야 한다. -->
      <Component Id="ShellBackground">
        <RegistryKey Root="HKCR" Key="Directory\Background\shell\OpenWithCSVViewer" ForceDeleteOnUninstall="yes">
          <RegistryValue Type="string" Value="Open with CSV Viewer(&amp;V)" KeyPath="yes" />
          <RegistryValue Name="Icon" Type="string" Value="[INSTALLFOLDER]CSV Viewer.exe" />
          <RegistryKey Key="command">
            <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]CSV Viewer.exe&quot; &quot;%V&quot;" />
          </RegistryKey>
        </RegistryKey>
      </Component>

    </ComponentGroup>

    <!-- ★ 설치/제거 '시작 전' 확인 팝업: Yes/No 로 사용자 동의를 받는다.
         함수형 VBScript(Binary 테이블에 임베드)라 반환값이 Windows Installer 로 전달된다:
           1 = 진행(Yes) · 2 = 사용자 취소(No → 깨끗한 user-exit, 치명적오류 대화상자 없음).
         반환값을 반영하려면 Return="check" 필수(완료 팝업의 Return="ignore" 와 대비).
         ExecuteAction '전'에 실행 → No 면 실제 설치/제거가 시작되기 '전에' 중단된다.
         MsgBox 는 대화형 데스크톱 필요 → immediate(사용자 컨텍스트). /qn 무인설치는 UI 시퀀스를
         아예 타지 않아 확인창이 안 뜨고 그대로 진행된다(완료 팝업과 동일). -->
    <Binary Id="ConfirmInstallScript"   SourceFile="$(sys.SOURCEFILEDIR)confirm_install.vbs" />
    <Binary Id="ConfirmUpgradeScript"   SourceFile="$(sys.SOURCEFILEDIR)confirm_upgrade.vbs" />
    <Binary Id="ConfirmUninstallScript" SourceFile="$(sys.SOURCEFILEDIR)confirm_uninstall.vbs" />
    <CustomAction Id="ConfirmInstall" BinaryRef="ConfirmInstallScript"
                  VBScriptCall="ConfirmInstall" Execute="immediate" Return="check" />
    <CustomAction Id="ConfirmUpgrade" BinaryRef="ConfirmUpgradeScript"
                  VBScriptCall="ConfirmUpgrade" Execute="immediate" Return="check" />
    <CustomAction Id="ConfirmUninstall" BinaryRef="ConfirmUninstallScript"
                  VBScriptCall="ConfirmUninstall" Execute="immediate" Return="check" />

    <!-- ★ 완료 안내 팝업: 설치/제거가 끝나면 메시지 박스를 띄운다.
         InstallUISequence(사용자 컨텍스트, UI 가 있을 때만)에서 ExecuteAction 직후 실행
         → /qn 무인 설치에서는 뜨지 않는다. Return=ignore 라 팝업이 실패해도 설치엔 영향 없음. -->
    <CustomAction Id="ShowInstallDone" Script="vbscript"
                  ScriptSourceFile="$(sys.SOURCEFILEDIR)popup_install.vbs"
                  Execute="immediate" Return="ignore" />
    <CustomAction Id="ShowUninstallDone" Script="vbscript"
                  ScriptSourceFile="$(sys.SOURCEFILEDIR)popup_uninstall.vbs"
                  Execute="immediate" Return="ignore" />

    <InstallUISequence>
      <!-- 작업 '시작 전' 확인(ExecuteAction 전). 세 상태를 조건으로 구분하며 정확히 하나만 뜬다:
             · 신규 설치 = 설치 안 됨 + 업/다운그레이드 대상 아님          → ConfirmInstall   ("install?")
             · 업그레이드 = 옛 버전 감지(WIX_UPGRADE_DETECTED)             → ConfirmUpgrade   ("update?")
             · 제거 토글  = 같은 버전이라 Installed → REMOVE=ALL           → ConfirmUninstall ("uninstall?")
           REMOVE/WIX_*_DETECTED 는 ExecuteAction 전(SetProperty·FindRelatedProducts)에 이미 세팅됨.
           No → user-exit 로 작업 중단. (더 최신 버전 설치 시엔 MajorUpgrade 가 먼저 다운그레이드 차단) -->
      <Custom Action="ConfirmInstall"   Before="ExecuteAction"
              Condition="NOT Installed AND NOT REMOVE AND NOT WIX_UPGRADE_DETECTED AND NOT WIX_DOWNGRADE_DETECTED" />
      <Custom Action="ConfirmUpgrade"   Before="ExecuteAction"
              Condition="WIX_UPGRADE_DETECTED AND NOT REMOVE" />
      <Custom Action="ConfirmUninstall" Before="ExecuteAction" Condition="REMOVE=&quot;ALL&quot;" />
      <!-- 설치/업그레이드 완료(제거가 아닐 때. 업그레이드는 Installed=거짓이라 함께 잡힌다) -->
      <Custom Action="ShowInstallDone" After="ExecuteAction" Condition="NOT Installed AND NOT REMOVE" />
      <!-- 제거 완료(토글 재실행 제거 또는 /x 제거) -->
      <Custom Action="ShowUninstallDone" After="ExecuteAction" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallUISequence>

  </Package>
</Wix>
